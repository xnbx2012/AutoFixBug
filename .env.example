# 必填：用于加密存储 GitHub Token 的主密钥（首次启动会自动生成）
ENCRYPTION_KEY=

# 管理员账号（可选，默认 admin）
ADMIN_USERNAME=admin

# 管理员密码（可选，默认 123456）
# 首次启动后会自动加密存储；若运行时仍为默认密码，系统将拒绝响应 API 请求
ADMIN_PASSWORD=

# Web 服务监听端口
PORT=3000

# 服务对外可访问的地址（用于生成 GitHub Webhook URL）
# 例如: https://your-domain.com 或 http://your-server-ip:3000
PUBLIC_BASE_URL=http://localhost:3000

# 任务处理并行度（同时处理的 issue 数量）
MAX_CONCURRENT_JOBS=1
